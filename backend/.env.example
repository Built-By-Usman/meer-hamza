# ------------------------------------------------------------------------------
# ENVIRONMENT CONFIGURATION FOR E-COMMERCE API
# ------------------------------------------------------------------------------
# Run this command to generate a cryptographically secure 256-bit secret key:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=940b54e311a3b118b76df479b183617300c3c9c6183e95973719b4864197e937

# Database Connection URI (Strictly requires asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce

# JWT Security Configurations
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS / Cookie settings
# Matches NEXT_PUBLIC_FRONTEND_URL from frontend environment definitions
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Operational States
ENVIRONMENT=production
LOG_LEVEL=INFO
